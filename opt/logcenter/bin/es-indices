#!/bin/bash

function exit_usage() {
    local status=${1:-0}
    [[ $status != 0 ]] && exec >&2
    cat << EOF
Usage: ${0#*/} [OPTION...]
List elasticsearch indices or print disk usage by alias or datastream

Available options:
  -w, --watch [SEC]     Listing in watch mode, ie. with periodic refresh; it
                        prints the last indices of each alias or datastream,
                        and single indices
  -s, --size            Size mode, grouped by alias or datastream
  -r, --size-raw        Output sizes in bytes, for size mode
  -n, --size-asc        Sort by size ascending, for size mode
  -N, --size-desc       Sort by size descending for size mode
  -a, --age             Age mode, displays min/max @timestamp per index
  -u, --utc             For age mode, display dates in UTC
  -l, --all             Force to include all system hidden indices, aliases
                        or datastreams using an '*,.*' filter in API calls

  -E, --grep            Post filter passed to grep -E before pretty columns
  -x, --invert-match    Invert grep post filter
  -v, --verbose         Display more columns
EOF
    exit "$status"
}

function mode_listing() {
    local headers column_right
    if [[ -z $VERBOSE ]]; then
        headers=h,s,idx,p,r,dc,dd,ss,pri.store.size,sc
        column_right=4,5,6,7,8,9,10
    else
        headers=h,s,idx,uuid,p,r,dc,dd,ss,pri.store.size,sc
        column_right=5,6,7,8,9,10,11
    fi
    es-curl "_cat/indices/$PATH_FILTER?v&h=$headers&s=i" |
        sed -e '1s/pri\.store\.size/pss/' |{
            # keep header line
            read -r; echo "$REPLY"
            if [[ -z $WATCHING ]]; then
                cat
            else
                # watch mode, print last indice of aliases/datastreams and single indices
                awk '
                ARGIND == 1 { if ($(NF) == "true") { keep[$2]=1; } is_aliased[$2]=1; }
                ARGIND == 2 { keep[$1]=1; }
                ARGIND == 3 && (keep[$3] || (!is_aliased[$3] && substr($3, 1, 4) != ".ds-")) { print $0; }
                '   <(es-curl "_cat/aliases/$PATH_FILTER?expand_wildcards=all&s=a") \
                    <(es-curl "_data_stream/$PATH_FILTER?expand_wildcards=all" |
                        jq -r '.data_streams |map(.indices |last |.index_name)[]') \
                    <(cat)
            fi |
            grep -E "$POST_FILTER" ${POST_FILTER_INVERT:+-v}
        } |
        column -t -o ' ' -R "$column_right"
}

function mode_age() {
    local IFS=$'\n' indices postdata
    indices=($(es-curl "_cat/indices/$PATH_FILTER?h=i&s=i" |
        grep -E "$POST_FILTER" ${POST_FILTER_INVERT:+-v}))
    for i in "${indices[@]}"; do
        postdata+="{\"index\":\"$i\"}"$'\n'
        postdata+="{\"size\":0,\"track_total_hits\":false,\"aggs\":{\"min_ts\":{\"min\":{\"field\":\"@timestamp\"}},\"max_ts\":{\"max\":{\"field\":\"@timestamp\"}}}}"$'\n'
    done
    local headers column_right
    if [[ -z $VERBOSE ]]; then
        headers=i,from,to
        column_right=
    else
        headers=i,from,to,min_ts,max_ts
        column_right=4,5
    fi
    {   echo "${headers//,/$'\t'}"
        es-curl _msearch -d "$postdata" |jq '
        def n3f:
            (. * 1000 |round) as $c |"\($c / 1000)" |
            (split(".") + [""]) as $p| $p[0] + "." + (($p[1] + "000")[0:3]);

        def to_local:
            #(.[:19] + "Z" | fromdateiso8601 | strflocaltime("%Y-%m-%dT%H:%M:%S%z")) as $l|
            #$l[:19] + .[19:-1] + $l[19:];
            # Workaround for github issue #2429 "strflocaltime always outputs +0000 ..."
            (.[:19] + "Z" |fromdateiso8601) as $t |
            (($t |strflocaltime("%Y-%m-%dT%H:%M:%S") |strptime("%Y-%m-%dT%H:%M:%S") |mktime) - $t) as $off |
            (if $off < 0 then "-" else "+" end) as $sign |
            ($off | fabs / 60) as $m |
            ($t |strflocaltime("%Y-%m-%dT%H:%M:%S")) + .[19:-1] +
                $sign + "0\($m / 60 | floor)"[-2:] + "0\($m % 60)"[-2:];

        def utc_or_local:
            if $utc == "1" then . else to_local end;

        .responses |to_entries |map(
            [$ARGS.positional[.key],
             (.value?.aggregations?.min_ts?.value_as_string| utc_or_local)? // "-",
             (.value?.aggregations?.max_ts?.value_as_string| utc_or_local)? // "-",
             (if $V == "1" then
                (((.value?.aggregations?.min_ts?.value/1000)| n3f)? // "-"),
                (((.value?.aggregations?.max_ts?.value/1000)| n3f)? // "-")
              else empty end)
            ] |join("\t")
        )[]
        ' -r --arg V "$VERBOSE" --arg utc "$UTC" --args "${indices[@]}"
    } |
    column -t -o ' ' -R "$column_right"
}

function mode_size() {
    awk -v "SIZE_RAW=$SIZE_RAW" \
        -v "SIZE_SORT=$SIZE_SORT" \
    '
function human(input, mult, sep, _sym) {
    _sym = 1;
    while (input >= mult && _sym < HSYM_LEN) {
        _sym++;
        input = input / mult;
    }
    return sprintf("%.1lf%s%s", input, sep, HSYM[_sym]);
}
BEGIN {
    HSYM_LEN = split(",K,M,G,T", HSYM, ",");
}
ARGIND == 1 || ARGIND == 2 {
    num_groups_by_indice[$2]++;
    indice2group[$2,num_groups_by_indice[$2]] = $1;
}
ARGIND == 3 {
    for (i = 1; i <= num_groups_by_indice[$3]; i++) {
        group = indice2group[$3,i];
        store_size_by_group[group] += $(NF-2)
        pri_store_size_by_group[group] += $(NF-1)
    }
}
END {
    print "group ss pss";
    # gawk specific sort
    ordered_groups_len = asorti(store_size_by_group, ordered_groups, SIZE_SORT)
    for (i = 1; i <= ordered_groups_len; i++) {
        group = ordered_groups[i];
        store_size = store_size_by_group[group];
        pri_store_size = pri_store_size_by_group[group];
        printf("%s %s %s\n", group,
            SIZE_RAW ? store_size : (human(store_size, 1024) "B"),
            SIZE_RAW ? pri_store_size : (human(pri_store_size, 1024) "B"));
    }
}
    '   <(es-curl "_cat/aliases/$PATH_FILTER?expand_wildcards=all&s=a") \
        <(es-curl "_data_stream/$PATH_FILTER?expand_wildcards=all" |
            jq -r '.data_streams |map(.name as $ds |.indices |map(.index_name)[] |"\($ds) \(.)") []') \
        <(es-curl "_cat/indices/$PATH_FILTER?s=i&bytes=b") |
    {
        # keep header line
        read -r; echo "$REPLY"
        grep -E "$POST_FILTER" ${POST_FILTER_INVERT:+-v}
    } |
    column -t -o ' ' -R 2,3
}

SIZE=
SIZE_RAW=
SIZE_SORT=@ind_str_asc
AGE=
UTC=
PATH_FILTER=${PATH_FILTER-'*,-.internal.*'}
VERBOSE=${VERBOSE:-}
WATCH=
WATCH_INTERVAL=5
WATCHING=${WATCHING:-}
POST_FILTER=${POST_FILTER:-^}
POST_FILTER_INVERT=${POST_FILTER_INVERT:-}
shopt -s extglob
while (( $# > 0 )); do
    case "$1" in
        -h|--help) exit_usage 0 ;;
        -s|--size) SIZE=1 ;;
        -r|--size-raw) SIZE_RAW=1 ;;
        -n|--size-asc) SIZE_SORT=@val_num_asc ;;
        -N|--size-desc) SIZE_SORT=@val_num_desc ;;
        -a|--age) AGE=1 ;;
        -u|--utc) UTC=1 ;;
        -l|--all) PATH_FILTER='*,.*' ;;
        -E|--grep) POST_FILTER=$2; shift ;;
        -x|--invert-match) POST_FILTER_INVERT=1 ;;
        -v|--verbose) VERBOSE=1 ;;
        -w|--watch) WATCH=1; [[ ${2:0:1} == [0-9]* ]] && { WATCH_INTERVAL=$2; shift; } ;;
        -+([srnNiaulxvwh]))
            for (( i = 1; i < ${#1}; i++ )); do
                case "${1:i:1}" in
                    s) SIZE=1 ;;
                    r) SIZE_RAW=1 ;;
                    n) SIZE_SORT=@val_num_asc ;;
                    N) SIZE_SORT=@val_num_desc ;;
                    a) AGE=1 ;;
                    u) UTC=1 ;;
                    l) PATH_FILTER='*,.*' ;;
                    x) POST_FILTER_INVERT=1 ;;
                    v) VERBOSE=1 ;;
                    w) WATCH=1 ;;
                    h) exit_usage 0 ;;
                esac
            done
            ;;
        *) exit_usage 1 ;;
    esac
    shift
done
shopt -u extglob

if [[ -n $WATCH ]]; then
    [[ -z ${WATCH_INTERVAL//[0-9]} ]] || exit_usage 1
    export WATCHING=1 PATH_FILTER POST_FILTER POST_FILTER_INVERT VERBOSE
    exec watch -n "$WATCH_INTERVAL" "$0"
elif [[ -n $AGE ]]; then
    mode_age
elif [[ -n $SIZE ]]; then
    mode_size
else
    mode_listing
fi
