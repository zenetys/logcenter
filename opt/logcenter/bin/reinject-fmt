function exit_usage(status)
    print('Usage: '..PROGNAME..' [option]\
Read log archives from stdin, format for reinject on stdout\n\
Available options:\
  -i, --id          Set reinject identifier (default yyyymmddHHMMSS)\
  -t, --type        Set log type (default syslog)\
  -s, --source      Set source IP (defaut from hostname field or 127.0.0.1)\
  -H, --hostname    Set default syslog hostname\
  -T, --tag         Set default syslog tag\
  -h, --help        Display this help\n\
Expected input is a stream of lines in the following format:\
  @reported/@received facility.severity hostname/ip program[pid]: message\
  @reported/@received facility.severity hostname program[pid]: message')
    os.exit(status or 0)
end

function main(arg)
    local i = 1
    while i <= #arg do
        if arg[i] == '-i' or arg[i] == '--id' then
            i = i + 1; DEFAULT_RJID = arg[i]
        elseif arg[i] == '-t' or arg[i] == '--type' then
            i = i + 1; DEFAULT_TYPE = arg[i]
        elseif arg[i] == '-s' or arg[i] == '--source' then
            i = i + 1; DEFAULT_SOURCE = arg[i]
        elseif arg[i] == '-H' or arg[i] == '--hostname' then
            i = i + 1; DEFAULT_HOSTNAME = arg[i]
        elseif arg[i] == '-T' or arg[i] == '--tag' then
            i = i + 1; DEFAULT_TAG = arg[i]
        elseif arg[i] == '-h' or arg[i] == '--help' then
            exit_usage(0)
        else
            exit_usage(1)
        end
        i = i + 1
    end

    LOG_RJID = DEFAULT_RJID
    LOG_TYPE = DEFAULT_TYPE
    LOG_SOURCE = DEFAULT_SOURCE
    LOG_ILINE = 0
    LOG_FILE = nil

    local line = nil

    while true do
        line = io.read('*line')
        if line == nil then break end

        LOG_ILINE = LOG_ILINE + 1
        status, err = pcall(process, line)
        if not status then
            perr(err)
        end
    end
end

status, err = pcall(main, arg)
if not status then
    perr(err)
    os.exit(2)
end
